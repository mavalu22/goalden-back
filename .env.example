# Goalden API — Environment Variables
#
# Copy this file to .env and fill in the values.
# Never commit .env — it is listed in .gitignore.
#
# Required variables are marked [REQUIRED].
# Optional variables show their default value.

# ── Server ─────────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Railway sets this automatically; override only for local dev.
# [optional] default: 8080
PORT=8080

# Application environment. Affects logging verbosity.
# [optional] default: development
ENV=development

# ── Database ────────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string.
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI mode)
# Use the "Session" pooler URL for local dev; "Transaction" pooler for Railway/serverless.
# [REQUIRED]
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Redis ───────────────────────────────────────────────────────────────────────

# Redis connection URL.
# For local dev: redis://localhost:6379 (started via docker-compose)
# For production: use an Upstash Redis URL (from Railway add-on or Upstash dashboard)
# [optional] default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Supabase Auth ───────────────────────────────────────────────────────────────

# Your Supabase project URL.
# Found in: Supabase dashboard → Project Settings → API → Project URL
# [REQUIRED]
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service role key (server-side key with full database access).
# Found in: Supabase dashboard → Project Settings → API → service_role key
# Keep this secret — never expose it in client-side code or public repos.
# [REQUIRED]
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase anon key (public, safe to share with clients).
# Found in: Supabase dashboard → Project Settings → API → anon key
# [optional]
SUPABASE_ANON_KEY=eyJ...

# ── CORS ────────────────────────────────────────────────────────────────────────

# Comma-separated list of origins allowed to make cross-origin requests.
# For local dev: http://localhost:3000,http://localhost:8080
# For production: set to your actual frontend domain
# [optional] default: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
